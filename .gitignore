# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib
wireguard-ui
wireguard-ui-v2

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories and files (remove the comment below to include it)
vendor/
assets/*
!assets/.gitkeep
node_modules/

# IDEs
.vscode
.idea

# Agent skills (e.g. npx skills add → .agents/skills)
.agents/
skills-lock.json

# Local agent tooling (e.g. Claude Code)
.claude/

.DS_Store

# Firebase Admin SDK service account JSON (FCM_CREDENTIALS_FILE / GOOGLE_APPLICATION_CREDENTIALS)
*firebase-adminsdk*.json

# Vim
.*.sw[op]

# Examples
examples/docker-compose/config
examples/docker-compose/db
